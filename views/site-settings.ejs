<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="/main.css" />
    <title>Site Settings</title>
</head>
<body>
    <div class="container">
        <h1>Site Settings</h1>
        <p class="subtitle">Site Settings Access - Manage site configuration</p>
        
        <div class="navigation-links">
            <a href="/organiser" class="button secondary">Back to Organiser Home</a>
            <a href="/" class="button secondary">Main Home Page</a>
        </div>

        <% if (errorMessage) { %>
            <div class="error-message">
                <p><%= errorMessage %></p>
            </div>
        <% } %>

        <div class="site-settings-form">
            <form action="/organiser/site-settings" method="post" class="event-form">
                <div class="form-group">
                    <label for="site_name">Site Name:</label>
                    <input type="text" id="site_name" name="site_name" value="<%= siteName || '' %>" required />
                </div>
                
                <div class="form-group">
                    <label for="site_description">Site Description:</label>
                    <textarea id="site_description" name="site_description" rows="4" required><%= siteDescription || '' %></textarea>
                </div>
                
                <div class="form-actions">
                    <button type="submit" class="button primary">Save Settings</button>
                    <a href="/organiser" class="button secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>

