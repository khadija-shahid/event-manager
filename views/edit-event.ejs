<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="/main.css" />
    <title>Edit Event</title>
</head>
<body>
    <div class="container">
        <h1>Edit Event</h1>
        <p class="subtitle">Update draft event details</p>
        <% if (event.created_at) { %>
            <p class="event-meta"><strong>Created:</strong> <%= new Date(event.created_at).toLocaleString() %></p>
        <% } %>
        
        <form action="/organiser/edit-event/<%= event.event_id %>" method="post" class="event-form">
            <div class="form-group">
                <label for="event_title">Event Title:</label>
                <input type="text" id="event_title" name="event_title" value="<%= event.event_title %>" required />
            </div>
            
            <div class="form-group">
                <label for="event_description">Event Description:</label>
                <textarea id="event_description" name="event_description" rows="4" required><%= event.event_description %></textarea>
            </div>
            
            <div class="form-group">
                <label for="event_date">Event Date:</label>
                <input type="date" id="event_date" name="event_date" value="<%= event.event_date %>" required />
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label for="full_price_ticket_quantity">Full Price Ticket Quantity:</label>
                    <input type="number" id="full_price_ticket_quantity" name="full_price_ticket_quantity" min="0" value="<%= event.full_price_ticket_quantity %>" required />
                </div>
                
                <div class="form-group">
                    <label for="full_price_ticket_price">Full Price Ticket Price (£):</label>
                    <input type="number" id="full_price_ticket_price" name="full_price_ticket_price" min="0" step="0.01" value="<%= event.full_price_ticket_price %>" required />
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label for="concession_ticket_quantity">Concession Ticket Quantity:</label>
                    <input type="number" id="concession_ticket_quantity" name="concession_ticket_quantity" min="0" value="<%= event.concession_ticket_quantity %>" required />
                </div>
                
                <div class="form-group">
                    <label for="concession_ticket_price">Concession Ticket Price (£):</label>
                    <input type="number" id="concession_ticket_price" name="concession_ticket_price" min="0" step="0.01" value="<%= event.concession_ticket_price %>" required />
                </div>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="button primary">Update Event</button>
                <a href="/organiser" class="button secondary">Cancel</a>
            </div>
        </form>
    </div>
</body>
</html>

