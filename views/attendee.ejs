<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="/main.css" />
    <title>Attendee Home Page</title>
</head>
<body>
    <div class="container">
        <% if (siteName) { %>
            <h1 class="site-name"><%= siteName %></h1>
        <% } %>
        <% if (siteDescription) { %>
            <p class="site-description"><%= siteDescription %></p>
        <% } %>
        <h2>Attendee Home Page</h2>
        <p class="subtitle">Attendee Access - Browse available events</p>
        
        <div class="navigation-links">
            <a href="/" class="button secondary">Main Home Page</a>
        </div>

        <div class="events-list">
            <h2>Published Events</h2>
            <% if (publishedEvents && publishedEvents.length > 0) { %>
                <div class="published-events">
                    <% publishedEvents.forEach(function(event) { %>
                        <a href="/attendee/event/<%= event.event_id %>" class="event-card-link">
                            <div class="event-card clickable-event">
                                <div class="event-header">
                                    <h3><%= event.event_title %></h3>
                                </div>
                                <div class="event-details">
                                    <p><strong>Event Date:</strong> <%= event.event_date %></p>
                                    <p><strong>Description:</strong> <%= event.event_description %></p>
                                </div>
                            </div>
                        </a>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="no-events">No published events available at this time.</p>
            <% } %>
        </div>
    </div>
</body>
</html>

