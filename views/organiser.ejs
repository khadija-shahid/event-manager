<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="/main.css" />
    <title>Organiser Control Page</title>
</head>
<body>
    <div class="container">
        <% if (siteName) { %>
            <h1 class="site-name"><%= siteName %></h1>
        <% } %>
        <% if (siteDescription) { %>
            <p class="site-description"><%= siteDescription %></p>
        <% } %>
        <h2>Organiser Home Page</h2>
        <p class="subtitle">Organiser Access - Manage your events</p>
        
        <div class="navigation-links">
            <a href="/" class="button secondary">Main Home Page</a>
            <a href="/organiser/site-settings" class="button secondary">Site Settings</a>
            <a href="/organiser/analytics" class="button secondary">Analytics</a>
        </div>
        
        <div class="actions">
            <a href="/organiser/add-event" class="button primary">Add New Event</a>
        </div>

        <% if (warningMessage) { %>
            <div class="warning-message">
                <p><%= warningMessage %></p>
            </div>
        <% } %>

        <div class="events-list">
            <h2>Published Events</h2>
            <% if (publishedEvents && publishedEvents.length > 0) { %>
                <div class="published-events">
                    <% publishedEvents.forEach(function(event) { %>
                        <div class="event-card <%= affectedEventId === event.event_id ? 'highlight-warning' : '' %>">
                            <div class="event-header">
                                <h3><%= event.event_title %></h3>
                                <span class="status published">Published</span>
                            </div>
                            <div class="event-details">
                                <p><strong>Event Date:</strong> <%= event.event_date %></p>
                                <p><strong>Published:</strong> <%= event.published_at ? new Date(event.published_at).toLocaleString() : 'N/A' %></p>
                                <div class="ticket-info">
                                    <p><strong>Full Price Tickets:</strong> <%= event.full_price_ticket_quantity %> available @ £<%= event.full_price_ticket_price %></p>
                                    <p><strong>Concession Tickets:</strong> <%= event.concession_ticket_quantity %> available @ £<%= event.concession_ticket_price %></p>
                                </div>
                            </div>
                            <div class="event-actions">
                                <form action="/organiser/delete-event/<%= event.event_id %>" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this event?');">
                                    <button type="submit" class="button small delete">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="no-events">No published events found.</p>
            <% } %>
        </div>

        <div class="events-list">
            <h2>Draft Events</h2>
            <% if (draftEvents && draftEvents.length > 0) { %>
                <div class="draft-events">
                    <% draftEvents.forEach(function(event) { %>
                        <div class="event-card draft-card <%= affectedEventId === event.event_id ? 'highlight-warning' : '' %>">
                            <div class="event-header">
                                <h3><%= event.event_title %></h3>
                                <span class="status draft">Draft</span>
                            </div>
                            <div class="event-details">
                                <p><strong>Created:</strong> <%= event.created_at ? new Date(event.created_at).toLocaleString() : 'N/A' %></p>
                            </div>
                            <div class="event-actions">
                                <a href="/organiser/edit-event/<%= event.event_id %>" class="button small">Edit</a>
                                <form action="/organiser/publish-event/<%= event.event_id %>" method="post" style="display: inline;">
                                    <button type="submit" class="button small publish">Publish</button>
                                </form>
                                <form action="/organiser/delete-event/<%= event.event_id %>" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this event?');">
                                    <button type="submit" class="button small delete">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="no-events">No draft events found. Create your first event to get started.</p>
            <% } %>
        </div>
    </div>
</body>
</html>

